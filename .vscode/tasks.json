{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Angular: serve",
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building|Application bundle generation",
          "endsPattern": "Local:|Watch mode enabled"
        }
      },
      "group": "build"
    },
    {
      "label": "Angular: production build",
      "type": "npm",
      "script": "build",
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
